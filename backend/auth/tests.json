{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {
        "email": "test_bv3@example.com",
        "nickname": "test_reader3",
        "display_name": "Тестовый Читатель",
        "password": "password123"
      },
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login user",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "email": "test_bv3@example.com",
        "password": "password123"
      },
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "email": "test_bv3@example.com",
        "password": "wrongpassword"
      },
      "expectedStatus": 401
    }
  ]
}